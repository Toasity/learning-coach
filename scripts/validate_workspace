#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from _common import ALLOWED_STATES, config, find_workspace, learning_dir, read_frontmatter, valid_course_id


def main() -> None:
    parser = argparse.ArgumentParser(description="Validate a learning workspace.")
    parser.add_argument("--workspace")
    args = parser.parse_args()

    root = find_workspace(args.workspace)
    cfg = config(root)
    learning = learning_dir(root, cfg)
    required = [
        root / str(cfg["inbox_root"]) / "new",
        root / str(cfg["inbox_root"]) / "unresolved",
        root / str(cfg["inbox_root"]) / "duplicates",
        learning / "courses",
        learning / "archive",
        learning / "shared",
        learning / "dashboard.md",
        learning / "portfolio.md",
        learning / "weekly-plan.md",
        learning / "task-inbox.md",
        learning / "review-queue.md",
        learning / "shared" / "knowledge-map.md",
        learning / "shared" / "error-log.md",
    ]
    errors = [f"Missing: {path}" for path in required if not path.exists()]
    active = 0
    course_entries = sorted((learning / "courses").iterdir()) if (learning / "courses").exists() else []
    for course in course_entries:
        if not course.is_dir() or course.name.startswith("_"):
            continue
        if not valid_course_id(course.name):
            errors.append(f"Invalid course ID: {course.name}")
        readme = course / "README.md"
        meta = read_frontmatter(readme)
        if meta.get("course_id") != course.name:
            errors.append(f"Course ID mismatch: {course}")
        status = meta.get("status")
        if status not in ALLOWED_STATES:
            errors.append(f"Invalid status in {readme}: {status}")
        if status == "active":
            active += 1
        for item in [
            "goal.md", "knowledge-map.md", "syllabus.md", "journal.md", "error-log.md",
            "external-index.md", "materials", "exercises", "solutions", "assessments", "projects",
        ]:
            if not (course / item).exists():
                errors.append(f"Missing course item: {course / item}")
    if active > int(cfg["active_course_limit"]):
        errors.append(f"Active course limit exceeded: {active}")

    print(f"Workspace: {root}")
    print(f"Active courses: {active}/{cfg['active_course_limit']}")
    if errors:
        for error in errors:
            print(f"ERROR {error}")
        raise SystemExit(1)
    print("OK workspace is valid")


if __name__ == "__main__":
    main()
